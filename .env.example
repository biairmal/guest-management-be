# Copy to .env and adjust as needed.
# Used when running the app or migrations against Docker Compose services.

# PostgreSQL (matches docker-compose postgres service)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/guest_management?sslmode=disable
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_DATABASE=guest_management
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Redis (matches docker-compose redis service; username: default, default password: redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=redis
REDIS_DB=0

# Swagger
SWAGGER_ENABLED=true
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=supersecret

# Tracing (matches docker-compose tempo service; OTLP/gRPC receiver)
TRACING_ENABLED=false
TRACING_ENDPOINT=localhost:4317
TRACING_INSECURE=true
TRACING_SAMPLE_RATE=1.0

# Logging: set to "file" (writes JSON to ./logs/app.log) so docker-compose's
# promtail service can tail and ship it to Loki. Leave "stdout" for plain console logs.
LOG_OUTPUT=stdout